module @TestModule {
  func.func @example(%arg0: i32, %arg1: i32) -> i32 {
    %c1_i32 = arith.constant 1 : i32
    %0 = arith.addi %arg0, %c1_i32 : i32
    %1 = arith.muli %0, %arg1 : i32
    %c0 = arith.constant 0 : index
    %c10 = arith.constant 10 : index
    %c1 = arith.constant 1 : index
    %2 = scf.for %arg2 = %c0 to %c10 step %c1 iter_args(%arg3 = %1) -> (i32) {
      %3 = arith.addi %arg3, %c1_i32 : i32
      %4 = arith.muli %3, %arg1 : i32
      scf.yield %4 : i32
    }
    return %2 : i32
  }
}

